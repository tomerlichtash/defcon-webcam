import json
import os
import subprocess
import urllib.parse

PORT = 8081
STATIC_DIR = os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "static")

HTML = """<!DOCTYPE html>
<html>
<head>
<title>Stars Outside - Camera Control Panel</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  @font-face { font-family: 'Exo 2'; font-weight: 400; src: url(/static/fonts/Exo2-Regular.ttf) format('truetype'); }
  @font-face { font-family: 'Exo 2'; font-weight: 700; src: url(/static/fonts/Exo2-Bold.ttf) format('truetype'); }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Exo 2', -apple-system, sans-serif; background: #1a1a2e; color: #eee; }
