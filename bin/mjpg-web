  .main-layout { display: flex; gap: 15px; }
  .stream-area { flex: 1; min-width: 0; }
  .stream-area img { width: 100%; border-radius: 8px; border: 2px solid #333; display: block; }
  #status { text-align: center; color: #888; font-size: 0.85em; margin-top: 8px; min-height: 20px; }
  .sidebar { width: 280px; flex-shrink: 0; display: flex; flex-direction: column; gap: 12px; }
  .panel { background: #16213e; border-radius: 8px; padding: 15px; }
  .panel h3 { color: #e94560; margin-bottom: 8px; font-size: 0.85em; text-transform: uppercase; }
  .btn-group { display: flex; gap: 5px; flex-wrap: wrap; }
  .btn { padding: 6px 12px; border: none; border-radius: 6px; cursor: pointer;
         background: #0f3460; color: #eee; font-size: 0.82em; transition: background 0.2s; }
  .btn:hover { background: #e94560; }
  .btn.active { background: #e94560; }
  .slider-row { display: flex; align-items: center; gap: 8px; margin: 4px 0; }
  .slider-row label { min-width: 55px; font-size: 0.82em; }
