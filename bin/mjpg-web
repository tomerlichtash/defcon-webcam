          <button class="btn" onclick="camCtl('restart')">Restart</button>
        </div>
      </div>
      <div class="panel">
        <h3>Server</h3>
        <div class="btn-group">
          <button class="btn" onclick="restartServer()">Restart Web UI</button>
        </div>
      </div>
    </div>
  </div>
