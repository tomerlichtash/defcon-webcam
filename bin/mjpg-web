#!/usr/bin/env python3
"""Web control panel for mjpg-streamer camera."""

import http.server
import json
import os
import subprocess
import urllib.parse

_root = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))

import sys

sys.path.insert(0, _root)

from lib.config import IS_LINUX, HAS_CAMERA
from lib.auth import is_authenticated, validate_session, refresh_session, start_oauth, exchange_oauth
from lib.sysinfo import get_sysinfo, get_defcon
from lib.geocode import init_geo_db, random_cities, lookup_many, city_count
from lib.alert_log import load_log, load_scan_log, log_event as alert_log_event
from lib.camera import take_snapshot
from lib.state import save_state
from lib.event_log import (
    log_event,
    load_events,
    count_events,
    prune,
    reset_db,
    init_db,
    migrate_from_jsonl,
)


import random
import threading
import time as _time

PORT = 8081
ALLOWED_SVCS = {"mjpg-alert", "mjpg-streamer", "mjpg-web"}

# Server-side state tracking for change detection
_prev_state = {"services": {}, "defcon": None, "temp": None}
_state_lock = threading.Lock()
_prune_interval = 3600  # prune every hour
STATIC_DIR = os.path.join(_root, "static")
TEMPLATE_DIR = os.path.join(_root, "templates")
DATA_DIR = os.path.join(_root, "data")

# Load quotes at startup — kept server-side so clients can't see sources
_quotes = {}
for _lang in ("en", "he"):
    _qpath = os.path.join(DATA_DIR, f"messages_{_lang}.json")
    try:
        with open(_qpath) as _qf:
            _quotes[_lang] = json.load(_qf)
    except Exception:
        _quotes[_lang] = []

with open(os.path.join(TEMPLATE_DIR, "index.html")) as f:
    HTML_TEMPLATE = f.read()

with open(os.path.join(TEMPLATE_DIR, "admin.html")) as f:
    ADMIN_TEMPLATE = f.read()

with open(os.path.join(TEMPLATE_DIR, "login.html")) as f:
    LOGIN_TEMPLATE = f.read()


def _detect_changes(info):
    """Compare sysinfo against previous state and log changes."""
    global _prev_state

    with _state_lock:
        # Service state changes
        svcs = info.get("services", {})
        for name, state in svcs.items():
            prev = _prev_state["services"].get(name)
            if prev and prev != state:
                log_event("system", label=name, value=state)
        _prev_state["services"] = dict(svcs)

        # DEFCON changes
        defcon = info.get("defcon")
        if defcon and defcon != _prev_state["defcon"]:
            if _prev_state["defcon"] is not None:
                log_event("system", label="defcon", value=defcon)
            _prev_state["defcon"] = defcon

        # Temperature warnings
        temp_str = info.get("temp")
        if temp_str:
            try:
                deg = float(temp_str.replace("°", ""))
            except ValueError:
                deg = 0
            prev_deg = _prev_state.get("temp") or 0
            if deg >= 70 and prev_deg < 70:
                log_event("system", label="temp", value=f"{temp_str} (high)")
            if deg >= 80 and prev_deg < 80:
                log_event("system", label="temp", value=f"{temp_str} (critical)")
            _prev_state["temp"] = deg


def _camera_ctl(action):
    """Start or stop mjpg-streamer (best-effort, logs failures)."""
    if not HAS_CAMERA:
        return
    try:
        subprocess.run(
            ["sudo", "systemctl", action, "mjpg-streamer"],
            capture_output=True,
            text=True,
            timeout=15,
        )
    except Exception as e:
        log_event("system", label="camera", value=f"{action} failed: {e}")


def _prune_thread():
    """Periodically prune old events."""
    while True:
        _time.sleep(_prune_interval)
        prune()


class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path.startswith("/api"):
            query = urllib.parse.urlparse(self.path).query
            params = urllib.parse.parse_qs(query)
            cmd = params.get("cmd", ["status"])[0]

            # --- Public commands (no auth required) ---

            if cmd == "quote":
                lang = params.get("lang", ["en"])[0]
                quotes = _quotes.get(lang, _quotes.get("en", []))
                if quotes:
                    idx = random.randrange(len(quotes))
                    entry = quotes[idx]
                    q = entry["quote"] if isinstance(entry, dict) else entry
                    self._json_response({"id": idx, "quote": q})
                else:
                    self._json_response({"quote": ""})
                return

            if cmd == "reveal":
                lang = params.get("lang", ["en"])[0]
                try:
                    idx = int(params.get("id", ["-1"])[0])
                except ValueError:
                    idx = -1
                quotes = _quotes.get(lang, _quotes.get("en", []))
                if 0 <= idx < len(quotes) and isinstance(quotes[idx], dict):
                    self._json_response({"source": quotes[idx].get("source", "")})
                else:
                    self._json_response({"source": ""})
                return

            if cmd == "defcon":
                self._json_response(get_defcon())
                return

            # --- All commands below require authentication ---
            if not is_authenticated(self.headers):
                self.send_response(401)
                self.send_header("Content-Type", "application/json")
                self.end_headers()
                self.wfile.write(b'{"error":"unauthorized"}')
                return

            if cmd == "simulate":
                try:
                    count = max(1, min(int(params.get("count", [100])[0]), 1000))
                except (ValueError, IndexError):
                    count = 100
                cities = random_cities(count)
                self._json_response({"alert_cities": cities})
                return

            if cmd == "eventlog":
                since = params.get("since", [None])[0]
                offset = int(params.get("offset", [0])[0])
                events = load_events(since=since, offset=offset)
                total = count_events()
                info = get_sysinfo()
                _detect_changes(info)
                self._json_response(
                    {"log": events, "total": total, "defcon": info.get("defcon")}
                )
                return

            if cmd == "alertlog":
                self._json_response({"log": load_log()})
                return

            if cmd == "scanlog":
                self._json_response({"log": load_scan_log()})
                return

            if cmd == "dbreset":
                reset_db()
                log_event("status", message="Event log cleared")
                self._json_response({"output": "Event log cleared"})
                return

            if cmd == "sysinfo":
                info = get_sysinfo()
                # Detect and log state changes
                _detect_changes(info)
                self._json_response({"sysinfo": info})
                return

            if cmd.startswith("svcctl "):
                if not IS_LINUX:
                    self._json_response(
                        {"output": "Service control not available on this platform"}
                    )
                    return
                parts = cmd.split()
                if len(parts) == 3:
                    action, svc = parts[1], parts[2]
                    if action in ("restart", "start") and svc in ALLOWED_SVCS:
                        log_event("status", message=f"{action.title()}ing {svc}...")
                        if svc == "mjpg-web":
                            self._json_response({"output": f"Restarting {svc}..."})
                            subprocess.Popen(
                                ["sudo", "systemctl", "restart", svc], close_fds=True
                            )
                            return
                        r = subprocess.run(
                            ["sudo", "systemctl", action, svc],
                            capture_output=True,
                            text=True,
                            timeout=15,
                        )
                        out = (r.stdout + r.stderr).strip() or f"{svc} {action} OK"
                        log_event("status", message=out)
                        self._json_response({"output": out})
                        return

            if cmd.startswith("defcon "):
                parts = cmd.split()
                if len(parts) < 2:
                    self._json_response({"error": "missing defcon level"})
                    return
                level = parts[1]
                ts = _time.strftime("%H:%M:%S")
                if level == "2":
                    save_state("defcon2")
                    alert_log_event("DEFCON 2", {"source": "manual", "alert": True})
                    log_event("status", message="DEFCON 2 set manually")
                    _camera_ctl("start")
                    self._json_response({"output": "DEFCON 2 - INCOMING MISSILES"})
                elif level == "4":
                    save_state("defcon4")
                    alert_log_event("DEFCON 4", {"source": "manual", "alert": True})
                    log_event("status", message="DEFCON 4 set manually")
                    _camera_ctl("start")
                    self._json_response({"output": "DEFCON 4 - INCOMING ALERT"})
                elif level == "5":
                    save_state("idle")
                    alert_log_event("DEFCON 5", None)
                    log_event("status", message="DEFCON 5 set manually")
                    _camera_ctl("stop")
                    self._json_response({"output": "DEFCON 5 - CLEAR SKIES"})
                else:
                    self._json_response({"error": "invalid defcon level"})
                return

            if cmd == "restart-web":
                if not IS_LINUX:
                    self._json_response(
                        {"output": "Service control not available on this platform"}
                    )
                    return
                log_event("status", message="Restarting web server...")
                self._json_response({"output": "Restarting web server..."})
                subprocess.Popen(
                    ["sudo", "systemctl", "restart", "mjpg-web"], close_fds=True
                )
                return

            if cmd.startswith("camctl "):
                if not HAS_CAMERA:
                    self._json_response(
                        {"output": "Camera not available on this platform"}
                    )
                    return
                parts = cmd.split()
                action = parts[1] if len(parts) > 1 else ""
                if action in ("start", "stop", "restart"):
                    log_event("status", message=f"Camera {action}...")
                    r = subprocess.run(
                        ["sudo", "systemctl", action, "mjpg-streamer"],
                        capture_output=True,
                        text=True,
                        timeout=15,
                    )
                    out = (r.stdout + r.stderr).strip() or f"Camera {action} OK"
                    log_event("status", message=out)
                    self._json_response({"output": out})
                    return

            if not HAS_CAMERA:
                self._json_response(
                    {"output": "Camera control not available on this platform"}
                )
                return

            allowed = ["day", "night", "indoor", "status", "focus"]
            prefixes = ["res ", "rotate ", "bright ", "zoom ", "fps "]
            if cmd not in allowed and not any(cmd.startswith(p) for p in prefixes):
                self.send_response(400)
                self.end_headers()
                self.wfile.write(b'{"error":"invalid command"}')
                return

            parts = cmd.split()
            if cmd != "status":
                log_event("status", message=f"Command: {cmd}")
            result = subprocess.run(
                ["/usr/local/bin/mjpg-ctl"] + parts,
                capture_output=True,
                text=True,
                timeout=30,
            )
            output = (result.stdout + result.stderr).strip()
            if cmd != "status" and output:
                log_event("status", message=output)
            self._json_response({"output": output})

        elif self.path.startswith("/admin/api"):
            if not is_authenticated(self.headers):
                self.send_response(401)
                self.send_header("Content-Type", "application/json")
                self.end_headers()
                self.wfile.write(b'{"error":"unauthorized"}')
                return

            query = urllib.parse.urlparse(self.path).query
            params = urllib.parse.parse_qs(query)
            cmd = params.get("cmd", [""])[0]

            if cmd == "verify":
                self._json_response({"ok": True, "admin_config": {}})
                return

            if cmd == "sysinfo":
                info = get_sysinfo()
                self._json_response({"sysinfo": info})
                return

            if cmd == "simulate":
                try:
                    count = max(1, min(int(params.get("count", [100])[0]), 1000))
                except (ValueError, IndexError):
                    count = 100
                cities = random_cities(count)
                self._json_response({"alert_cities": cities})
                return

            if cmd == "dbreset":
                reset_db()
                log_event("status", message="Event log cleared (admin)")
                self._json_response({"output": "Event log cleared"})
                return

            if cmd.startswith("svcctl "):
                if not IS_LINUX:
                    self._json_response(
                        {"output": "Service control not available on this platform"}
                    )
                    return
                parts = cmd.split()
                if len(parts) == 3:
                    action, svc = parts[1], parts[2]
                    if action in ("restart", "start") and svc in ALLOWED_SVCS:
                        log_event("status", message=f"Admin: {action}ing {svc}")
                        r = subprocess.run(
                            ["sudo", "systemctl", action, svc],
                            capture_output=True,
                            text=True,
                            timeout=15,
                        )
                        out = (r.stdout + r.stderr).strip() or f"{svc} {action} OK"
                        self._json_response({"output": out})
                        return

            self._json_response({"error": "unknown command"})

        elif self.path.startswith("/admin"):
            # Validate session cookie before serving admin page
            token = self._session_cookie()
            if not token or not validate_session(token):
                self.send_response(302)
                self.send_header("Location", "/login")
                self.end_headers()
                return
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.end_headers()
            self.wfile.write(ADMIN_TEMPLATE.encode())

        elif self.path.startswith("/login"):
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.end_headers()
            self.wfile.write(LOGIN_TEMPLATE.encode())

        elif self.path.startswith("/auth/callback"):
            query = urllib.parse.urlparse(self.path).query
            params = urllib.parse.parse_qs(query)
            code = params.get("code", [""])[0]
            if not code:
                self.send_response(302)
                self.send_header("Location", "/login?error=missing_code")
                self.end_headers()
                return
            session_jwt, refresh_jwt = exchange_oauth(code)
            if not session_jwt:
                self.send_response(302)
                self.send_header("Location", "/login?error=exchange_failed")
                self.end_headers()
                return
            self.send_response(302)
            self.send_header("Location", "/admin")
            self.send_header(
                "Set-Cookie",
                f"admin_session={session_jwt}; Path=/; HttpOnly; SameSite=Lax",
            )
            if refresh_jwt:
                self.send_header(
                    "Set-Cookie",
                    f"admin_refresh={refresh_jwt}; Path=/; HttpOnly; SameSite=Lax",
                )
            self.end_headers()

        elif self.path.startswith("/auth/google"):
            host = self.headers.get("Host", "localhost:8081")
            scheme = "https" if "443" in host else "http"
            return_url = f"{scheme}://{host}/auth/callback"
            redirect_url = start_oauth("google", return_url)
            if redirect_url:
                self.send_response(302)
                self.send_header("Location", redirect_url)
                self.end_headers()
            else:
                self.send_response(302)
                self.send_header("Location", "/login?error=oauth_start_failed")
                self.end_headers()

        elif self.path.startswith("/static/"):
            rel = self.path[len("/static/") :].split("?")[0]
            # Admin-only JS modules require auth cookie
            _admin_only = {
                "js/admin.js",
                "js/camera.js",
                "js/sysinfo.js",
                "js/channels.js",
                "js/eventlog.js",
            }
            if rel in _admin_only:
                token = self._session_cookie()
                if not token or not validate_session(token):
                    self.send_response(403)
                    self.end_headers()
                    return
            fpath = os.path.realpath(os.path.join(STATIC_DIR, rel))
            if not fpath.startswith(os.path.realpath(STATIC_DIR) + os.sep):
                self.send_response(403)
                self.end_headers()
                return
            if os.path.isfile(fpath):
                ext = os.path.splitext(fpath)[1]
                ctypes = {
                    ".css": "text/css",
                    ".js": "application/javascript",
                    ".html": "text/html",
                    ".json": "application/json",
                }
                self.send_response(200)
                self.send_header(
                    "Content-Type", ctypes.get(ext, "application/octet-stream")
                )
                self.send_header("Cache-Control", "no-cache")
                self.end_headers()
                with open(fpath, "rb") as f:
                    self.wfile.write(f.read())
            else:
                self.send_response(404)
                self.end_headers()
        else:
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.end_headers()
            self.wfile.write(HTML_TEMPLATE.encode())

    def _cookie(self, name):
        """Extract a named cookie value from the Cookie header."""
        for part in self.headers.get("Cookie", "").split(";"):
            part = part.strip()
            if part.startswith(f"{name}="):
                return part[len(name) + 1 :]
        return None

    def do_POST(self):
        if self.path == "/admin/api/refresh":
            # Try refresh token from cookie first, fall back to POST body
            token = self._cookie("admin_refresh")
            if not token:
                length = int(self.headers.get("Content-Length", 0))
                body = self.rfile.read(length).decode() if length else "{}"
                try:
                    data = json.loads(body)
                except Exception:
                    data = {}
                token = data.get("refresh_token", "")
            new_session = refresh_session(token)
            if new_session:
                self.send_response(200)
                self.send_header("Content-Type", "application/json")
                self.send_header(
                    "Set-Cookie",
                    f"admin_session={new_session}; Path=/; HttpOnly; SameSite=Lax",
                )
                self.end_headers()
                self.wfile.write(json.dumps({"sessionJwt": new_session}).encode())
            else:
                self.send_response(401)
                self.send_header("Content-Type", "application/json")
                self.end_headers()
                self.wfile.write(b'{"error":"refresh failed"}')
            return

        if self.path.startswith("/api/publish"):
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length).decode() if length else "{}"
            try:
                data = json.loads(body)
            except Exception:
                data = {}
            targets = data.get("targets", [])
            caption = data.get("caption", "Stars Outside")
            results = {}
            log_event("status", message=f"Publishing to {', '.join(targets)}...")
            try:
                take_snapshot()
            except Exception as e:
                log_event("status", message=f"Snapshot error: {e}")
                self._json_response({"results": {"snapshot": str(e)}})
                return
            for t in targets:
                if t == "telegram":
                    try:
                        from lib.telegram import send_telegram

                        send_telegram(caption)
                        results["telegram"] = "ok"
                    except Exception as e:
                        results["telegram"] = str(e)
                elif t == "twitter":
                    try:
                        from lib.twitter import send_tweet

                        send_tweet(caption)
                        results["twitter"] = "ok"
                    except Exception as e:
                        results["twitter"] = str(e)
            pub_summary = ", ".join(f"{k}: {v}" for k, v in results.items())
            log_event("status", message=f"Published: {pub_summary}")
            self._json_response({"results": results})
        else:
            self.send_response(404)
            self.end_headers()

    def _session_cookie(self):
        """Extract admin_session token from Cookie header."""
        return self._cookie("admin_session")

    def _json_response(self, data):
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(json.dumps(data).encode())

    def log_message(self, format, *args):
        pass


if __name__ == "__main__":
    # Initialize databases
    init_db()
    init_geo_db()
    geo_count = city_count()
    if geo_count > 0:
        print(f"Geocode DB: {geo_count} cities")
    else:
        print("Geocode DB is empty. Run: python3 bin/populate-geo")
    # Migrate from JSONL if it exists (one-time)
    migrated = migrate_from_jsonl()
    if migrated:
        print(f"Migrated {migrated} events from JSONL to SQLite")
    prune()
    log_event("status", message="Web server started")

    # Start background pruning thread
    t = threading.Thread(target=_prune_thread, daemon=True)
    t.start()

    server = http.server.HTTPServer(("0.0.0.0", PORT), Handler)
    print(f"Server running on http://0.0.0.0:{PORT}")
    server.serve_forever()
