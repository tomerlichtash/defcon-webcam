<script>
function setActive(group, val) {
  var grp = document.querySelector('[data-group="' + group + '"]');
  if (!grp) return;
  grp.querySelectorAll('.btn').forEach(function(b) {
    b.classList.toggle('active', b.getAttribute('data-val') === val);
  });
}

function applyStatus(output) {
  var lines = output.split('\\n');
  lines.forEach(function(l) {
    var m;
    if (m = l.match(/Mode: (\\w+)/)) setActive('mode', m[1]);
    if (m = l.match(/Resolution: (\\w+)/)) setActive('res', m[1]);
    if (m = l.match(/Rotation: (\\d+)/)) setActive('rotation', m[1]);
    if (m = l.match(/Brightness: (\\d+)/)) {
      document.getElementById('bright').value = m[1];
      sliderUpdate('bright', m[1]);
    }
    if (m = l.match(/FPS: (\\d+)/)) setActive('fps', m[1]);
    if (m = l.match(/Zoom: (\\d+)/)) {
      document.getElementById('zoom').value = m[1];
      sliderUpdate('zoom', m[1]);
    }
  });
}

function cmdToGroup(c) {
  if (c === 'day' || c === 'night' || c === 'indoor') return {group: 'mode', val: c};
  var m;
  if (m = c.match(/^res (\\w+)/)) return {group: 'res', val: m[1]};
  if (m = c.match(/^rotate (\\d+)/)) return {group: 'rotation', val: m[1]};
  if (m = c.match(/^fps (\\d+)/)) return {group: 'fps', val: m[1]};
  return null;
}

function cmd(c) {
  document.getElementById('status').textContent = 'Applying: ' + c + '...';
  fetch('/api?cmd=' + encodeURIComponent(c))
    .then(function(r) { return r.json(); })
    .then(function(d) {
      document.getElementById('status').textContent = d.output || 'Done';
      var g = cmdToGroup(c);
      if (g) setActive(g.group, g.val);
      if (c.startsWith('res ') || c.startsWith('rotate ') || c.startsWith('fps ') || c === 'day' || c === 'night' || c === 'indoor') {
        countdown(5);
      }
    })
    .catch(function(e) { document.getElementById('status').textContent = 'Error: ' + e; });
}

function countdown(sec) {
  var el = document.getElementById('status');
  var left = sec;
  var iv = setInterval(function() {
    el.textContent = 'Refreshing stream in ' + left + 's...';
    left--;
    if (left < 0) {
      clearInterval(iv);
      el.textContent = '';
      var img = document.getElementById('stream');
      img.src = img.src.split('?')[0] + '?action=stream&t=' + Date.now();
    }
  }, 1000);
}

function sliderUpdate(id, val) {
  document.getElementById(id + '-val').textContent = val;
}

var camOn = false;

function updateCamBtn() {
  var btn = document.getElementById('cam-toggle');
  btn.textContent = camOn ? 'On' : 'Off';
  btn.classList.toggle('active', camOn);
}

function camCtl(action) {
  document.getElementById('status').textContent = 'Camera: ' + action + '...';
  fetch('/api?cmd=camctl+' + action)
    .then(function(r) { return r.json(); })
    .then(function(d) {
      document.getElementById('status').textContent = d.output || 'Done';
      loadSysInfo();
      if (action !== 'stop') {
        countdown(3);
      }
    })
    .catch(function(e) { document.getElementById('status').textContent = 'Error: ' + e; });
}

function restartServer() {
  document.getElementById('status').textContent = 'Restarting web server...';
  fetch('/api?cmd=restart-web').catch(function() {});
  setTimeout(function() { location.reload(); }, 3000);
}

function camToggle() {
  camCtl(camOn ? 'stop' : 'start');
}

function dot(active) {
  return '<span class="svc-dot ' + (active ? 'up' : 'down') + '"></span>';
}

function loadSysInfo() {
  fetch('/api?cmd=sysinfo')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var info = d.sysinfo || {};
      if (info.uptime) document.getElementById('sb-uptime').textContent = info.uptime;
      if (info.load) {
        var el = document.getElementById('sb-load');
        el.textContent = 'CPU: ' + info.load;
        var pct = parseInt(info.load);
        el.style.color = pct < 60 ? '#4ecca3' : pct < 80 ? '#f0a500' : '#e94560';
      }
      if (info.temp) {
        var el = document.getElementById('sb-temp');
        el.textContent = 'Temp: ' + info.temp;
        var deg = parseFloat(info.temp);
        el.style.color = deg < 60 ? '#4ecca3' : deg < 70 ? '#f0a500' : deg < 80 ? '#e94560' : '#ff0000';
      }

      var svcs = info.services || {};
      var html = '';
      Object.keys(svcs).forEach(function(name) {
        var active = svcs[name] === 'active';
        html += dot(active) + name + '  ';
        if (name === 'mjpg-streamer') { camOn = active; updateCamBtn(); }
      });
      document.getElementById('sb-services').innerHTML = html || 'Services: ?';

      if (info.defcon) {
        var ds = document.getElementById('defcon-state');
        ds.textContent = info.defcon;
        ds.style.color = info.defcon === 'DEFCON 2' ? '#ff0000' : info.defcon === 'DEFCON 4' ? '#00cc00' : '#4488ff';
        document.title = 'Stars Outside - ' + info.defcon;
      }
    })
    .catch(function() {});
}

// Load current status on page load
fetch('/api?cmd=status')
  .then(function(r) { return r.json(); })
  .then(function(d) { applyStatus(d.output); });

loadSysInfo();
setInterval(loadSysInfo, 30000);
</script>
</body>
</html>"""


def get_sysinfo():
    """Gather service status, uptime, load, and temperature."""
    info = {}

    # Service statuses
    services = {}
    for svc in ["mjpg-streamer", "mjpg-alert"]:
        try:
            r = subprocess.run(["systemctl", "is-active", svc],
                               capture_output=True, text=True, timeout=5)
            services[svc] = r.stdout.strip()
        except Exception:
            services[svc] = "unknown"

    # Check if ffmpeg is running
    try:
        r = subprocess.run(["pgrep", "-c", "ffmpeg"],
                           capture_output=True, text=True, timeout=5)
        services["ffmpeg"] = "active" if r.returncode == 0 else "inactive"
    except Exception:
        services["ffmpeg"] = "unknown"

    info["services"] = services

    # Uptime
    try:
        r = subprocess.run(["uptime", "-p"], capture_output=True, text=True, timeout=5)
        info["uptime"] = r.stdout.strip()
    except Exception:
        pass

    # Load average
    try:
        with open("/proc/loadavg") as f:
            parts = f.read().split()
            info["load"] = str(min(round(float(parts[0]) * 100 / 4), 100)) + "%"
    except Exception:
        pass

    # CPU temperature
    try:
        with open("/sys/class/thermal/thermal_zone0/temp") as f:
            temp_c = int(f.read().strip()) / 1000
            info["temp"] = f"{temp_c:.1f}°"
    except Exception:
        pass

    # DEFCON state
    try:
        with open("/tmp/mjpg-alert-state") as f:
            state = f.read().strip()
            if state == "defcon2":
                info["defcon"] = "DEFCON 2"
            elif state == "defcon4":
                info["defcon"] = "DEFCON 4"
            else:
                info["defcon"] = "DEFCON 5"
    except Exception:
        info["defcon"] = "DEFCON 5"

    return info


class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path.startswith('/api'):
            query = urllib.parse.urlparse(self.path).query
            params = urllib.parse.parse_qs(query)
            cmd = params.get('cmd', ['status'])[0]

            # System info endpoint
            if cmd == 'sysinfo':
                self.send_response(200)
                self.send_header('Content-Type', 'application/json')
                self.send_header('Access-Control-Allow-Origin', '*')
                self.end_headers()
                self.wfile.write(json.dumps({"sysinfo": get_sysinfo()}).encode())
                return

            # Restart web server
            if cmd == 'restart-web':
                self.send_response(200)
                self.send_header('Content-Type', 'application/json')
                self.send_header('Access-Control-Allow-Origin', '*')
                self.end_headers()
                self.wfile.write(b'{"output":"Restarting web server..."}')
                subprocess.Popen(['sudo', 'systemctl', 'restart', 'mjpg-web'],
                                 close_fds=True)
                return

            # Camera on/off/restart
            if cmd.startswith('camctl '):
                action = cmd.split()[1]
                if action in ('start', 'stop', 'restart'):
                    r = subprocess.run(['sudo', 'systemctl', action, 'mjpg-streamer'],
                                       capture_output=True, text=True, timeout=15)
                    self.send_response(200)
                    self.send_header('Content-Type', 'application/json')
                    self.send_header('Access-Control-Allow-Origin', '*')
                    self.end_headers()
                    out = (r.stdout + r.stderr).strip() or f'Camera {action} OK'
                    self.wfile.write(json.dumps({"output": out}).encode())
                    return

            # Only allow known commands
            allowed = ['day', 'night', 'indoor', 'status', 'focus']
            prefixes = ['res ', 'rotate ', 'bright ', 'zoom ', 'fps ']
            if cmd not in allowed and not any(cmd.startswith(p) for p in prefixes):
                self.send_response(400)
                self.end_headers()
                self.wfile.write(b'{"error":"invalid command"}')
                return
            parts = cmd.split()
            result = subprocess.run(['/usr/local/bin/mjpg-ctl'] + parts,
                                    capture_output=True, text=True, timeout=30)
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            output = (result.stdout + result.stderr).strip()
            self.wfile.write(json.dumps({"output": output}).encode())
        elif self.path.startswith('/static/'):
            rel = self.path[len('/static/'):]
            fpath = os.path.join(STATIC_DIR, rel)
            if os.path.isfile(fpath):
                ext = os.path.splitext(fpath)[1]
                ctypes = {'.ttf': 'font/ttf', '.woff2': 'font/woff2', '.css': 'text/css'}
                self.send_response(200)
                self.send_header('Content-Type', ctypes.get(ext, 'application/octet-stream'))
                self.send_header('Cache-Control', 'public, max-age=86400')
                self.end_headers()
                with open(fpath, 'rb') as f:
                    self.wfile.write(f.read())
            else:
                self.send_response(404)
                self.end_headers()
        else:
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            host = self.headers.get('Host', '10.0.0.238:8081').split(':')[0]
            self.wfile.write(HTML.replace('__HOST__', host).encode())

    def log_message(self, format, *args):
        pass

if __name__ == '__main__':
    server = http.server.HTTPServer(('0.0.0.0', PORT), Handler)
    print(f"Control panel running on http://0.0.0.0:{PORT}")
    server.serve_forever()
