#!/usr/bin/env python3
"""Monitor Pikud HaOref alerts for Gush Dan."""

import os
import sys
import time

_root = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, _root)

from lib.config import CHECK_INTERVAL, WATCH_TERMS, get_current_mode
from lib.state import state, save_state, load_state, set_display
from lib import state as state_mod
from lib.oref import check_alerts
from lib.twitter import post_tweet
from lib.telegram import post_telegram


def main():
    term_count = len(WATCH_TERMS)
    print("Monitoring alerts for Gush Dan (" + str(term_count) + " terms)...", flush=True)

    # Restore persisted state
    state_mod.state = load_state()
    if state_mod.state == "defcon2":
        ts = time.strftime("%H:%M:%S")
        set_display(alert="DEFCON 2 - INCOMING MISSILES - " + ts)
        print("Resuming in DEFCON 2 (persisted state)", flush=True)
    elif state_mod.state == "defcon4":
        ts = time.strftime("%H:%M:%S")
        set_display(defcon4="DEFCON 4 - ALERT INCOMING - " + ts)
        print("Resuming in DEFCON 4 (persisted state)", flush=True)
    else:
        state_mod.state = "idle"
        set_display(idle="DEFCON 5")
        print("Starting in DEFCON 5", flush=True)

    while True:
        result = check_alerts()

        if result == "ended":
            if state_mod.state != "idle":
                ts = time.strftime("%H:%M:%S")
                print("Event ended at " + ts + ", back to DEFCON 5", flush=True)
                state_mod.state = "idle"
                save_state("idle")
                set_display(idle="DEFCON 5")

        elif result == "preemptive":
            if state_mod.state == "idle":
                ts = time.strftime("%H:%M:%S")
                print("DEFCON 4: preemptive alert - " + ts, flush=True)
                state_mod.state = "defcon4"
                save_state("defcon4")
                set_display(defcon4="DEFCON 4 - ALERT INCOMING - " + ts)

        elif result == "actual":
            if state_mod.state in ("idle", "defcon4"):
                ts = time.strftime("%H:%M:%S")
                ts_tweet = time.strftime("%H:%M:%S")
                print("DEFCON 2: incoming missiles - " + ts, flush=True)
                state_mod.state = "defcon2"
                save_state("defcon2")
                set_display(alert="DEFCON 2 - INCOMING MISSILES - " + ts)
                tweet_text = "DEFCON 2 - INCOMING MISSILES\n" + ts_tweet
                mode = get_current_mode()
                tweet_cancelled = False
                for _ in range(5):
                    time.sleep(CHECK_INTERVAL)
                    interim = check_alerts()
                    if interim == "ended":
                        print("State changed during tweet delay, cancelling tweet", flush=True)
                        state_mod.state = "idle"
                        save_state("idle")
                        set_display(idle="DEFCON 5")
                        tweet_cancelled = True
                        break
                if not tweet_cancelled and state_mod.state == "defcon2":
                    post_tweet(tweet_text, mode)
                    post_telegram(tweet_text, mode)

        time.sleep(CHECK_INTERVAL)


if __name__ == "__main__":
    main()
