                 background: #16213e; border-radius: 8px; padding: 8px 16px; margin-bottom: 10px;
                 font-size: 0.85em; color: #aaa; }
  .status-bar .title { color: #e94560; font-size: 1.3em; font-weight: bold; margin-right: auto; text-transform: uppercase; }
  .status-bar .item { white-space: nowrap; }
  .defcon-panel { text-align: center; font-size: 1.1em; font-weight: bold; }
  .svc-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 4px; vertical-align: middle; }
  .svc-dot.up { background: #4ecca3; }
