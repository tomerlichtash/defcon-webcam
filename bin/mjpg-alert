#!/usr/bin/env python3
"""Monitor Pikud HaOref alerts for Gush Dan."""

import os
import signal
import subprocess
import sys
import time

_root = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, _root)

from lib.config import CHECK_INTERVAL, WATCH_TERMS, HAS_CAMERA
from lib.oref import backoff_delay
from lib.state import save_state, load_state, set_display
from lib import state as state_mod
from lib.oref import check_alerts
from lib.alert_log import log_event

CTL = "/usr/local/bin/mjpg-ctl"
_running = True


def _shutdown(signum, _frame):
    """Handle SIGTERM/SIGINT for graceful shutdown."""
    global _running
    print(f"Received signal {signum}, shutting down...", flush=True)
    _running = False


signal.signal(signal.SIGTERM, _shutdown)
signal.signal(signal.SIGINT, _shutdown)


def apply_camera_profile(profile):
    """Switch camera between resting and alert profiles."""
    if not HAS_CAMERA:
        return
    if profile == "rest":
        print("Resting mode: stopping camera", flush=True)
        subprocess.run(["sudo", "systemctl", "stop", "mjpg-streamer"], timeout=15)
    elif profile == "alert":
        print("Alert mode: starting camera (720p, 24fps)", flush=True)
        subprocess.run(["sudo", "systemctl", "start", "mjpg-streamer"], timeout=15)
        time.sleep(3)
        subprocess.run([CTL, "res", "mid"], timeout=30)
        subprocess.run([CTL, "fps", "24"], timeout=30)


def main():
    term_count = len(WATCH_TERMS)
    print(f"Monitoring alerts for Gush Dan ({term_count} terms)...", flush=True)

    # Restore persisted state
    state_mod.state = load_state()
    if state_mod.state == "defcon2":
        ts = time.strftime("%H:%M:%S")
        set_display(alert=f"INCOMING MISSILES - {ts}")
        apply_camera_profile("alert")
        print("Resuming in DEFCON 2 (persisted state)", flush=True)
    elif state_mod.state == "defcon4":
        ts = time.strftime("%H:%M:%S")
        set_display(defcon4=f"INCOMING ALERT - {ts}")
        apply_camera_profile("alert")
        print("Resuming in DEFCON 4 (persisted state)", flush=True)
    else:
        state_mod.state = "idle"
        set_display(idle="CLEAR SKIES")
        apply_camera_profile("rest")
        print("Starting in DEFCON 5", flush=True)

    while _running:
        result, raw_data = check_alerts()

        if result == "ended":
            if state_mod.state != "idle":
                ts = time.strftime("%H:%M:%S")
                print(f"Event ended at {ts}, back to DEFCON 5", flush=True)
                log_event(5, raw_data)
                state_mod.state = "idle"
                save_state("idle")
                set_display(idle="CLEAR SKIES")
                apply_camera_profile("rest")

        elif result == "preemptive":
            if state_mod.state == "idle":
                ts = time.strftime("%H:%M:%S")
                print(f"DEFCON 4: preemptive alert - {ts}", flush=True)
                log_event(4, raw_data)
                state_mod.state = "defcon4"
                save_state("defcon4")
                set_display(defcon4=f"INCOMING ALERT - {ts}")
                apply_camera_profile("alert")

        elif result == "actual":
            if state_mod.state in ("idle", "defcon4"):
                ts = time.strftime("%H:%M:%S")
                print(f"DEFCON 2: incoming missiles - {ts}", flush=True)
                log_event(2, raw_data)
                state_mod.state = "defcon2"
                save_state("defcon2")
                set_display(alert=f"INCOMING MISSILES - {ts}")
                apply_camera_profile("alert")

        time.sleep(CHECK_INTERVAL + backoff_delay())

    print("Alert monitor stopped", flush=True)


if __name__ == "__main__":
    main()
