  @media (max-width: 800px) {
    .main-layout { flex-direction: column; }
    .sidebar { width: 100%; flex-direction: row; flex-wrap: wrap; }
    .sidebar .panel { flex: 1 1 140px; }
  }
</style>
</head>
<body>
<div class="container">
  <div class="status-bar" id="status-bar">
    <span class="title">Stars Outside</span>
    <span class="item" id="sb-uptime">Uptime: ...</span>
    <span class="item" id="sb-load">Load: ...</span>
    <span class="item" id="sb-temp">Temp: ...</span>
    <span class="item" id="sb-services">Services: ...</span>
  </div>
  <div class="main-layout">
    <div class="stream-area">
      <img id="stream" src="http://__HOST__:8080/?action=stream" alt="Camera Stream">
      <div id="status"></div>
    </div>
    <div class="sidebar">
      <div class="panel">
        <div class="defcon-panel" id="defcon-state">DEFCON 5</div>
      </div>
      <div class="panel">
        <h3>Mode</h3>
        <div class="btn-group" data-group="mode">
          <button class="btn" data-val="day" onclick="cmd('day')">Day</button>
          <button class="btn" data-val="night" onclick="cmd('night')">Night</button>
          <button class="btn" data-val="indoor" onclick="cmd('indoor')">Indoor</button>
        </div>
      </div>
      <div class="panel">
        <h3>Resolution</h3>
        <div class="btn-group" data-group="res">
          <button class="btn" data-val="low" onclick="cmd('res low')">480p</button>
          <button class="btn" data-val="mid" onclick="cmd('res mid')">720p</button>
          <button class="btn" data-val="high" onclick="cmd('res high')">1080p</button>
        </div>
      </div>
      <div class="panel">
        <h3>Rotation</h3>
        <div class="btn-group" data-group="rotation">
          <button class="btn" data-val="0" onclick="cmd('rotate 0')">0&deg;</button>
          <button class="btn" data-val="90" onclick="cmd('rotate 90')">90&deg;</button>
          <button class="btn" data-val="180" onclick="cmd('rotate 180')">180&deg;</button>
          <button class="btn" data-val="270" onclick="cmd('rotate 270')">270&deg;</button>
        </div>
      </div>
      <div class="panel">
        <h3>FPS</h3>
        <div class="btn-group" data-group="fps">
          <button class="btn" data-val="5" onclick="cmd('fps 5')">5</button>
          <button class="btn" data-val="10" onclick="cmd('fps 10')">10</button>
          <button class="btn" data-val="15" onclick="cmd('fps 15')">15</button>
          <button class="btn" data-val="24" onclick="cmd('fps 24')">24</button>
          <button class="btn" data-val="30" onclick="cmd('fps 30')">30</button>
        </div>
      </div>
      <div class="panel">
        <h3>Brightness</h3>
        <div class="slider-row">
          <label>Level</label>
          <input type="range" id="bright" min="0" max="100" value="58" oninput="sliderUpdate('bright',this.value)" onchange="cmd('bright '+this.value)">
          <span class="val" id="bright-val">58</span>
        </div>
      </div>
      <div class="panel">
        <h3>Zoom</h3>
        <div class="slider-row">
          <label>Level</label>
          <input type="range" id="zoom" min="100" max="500" value="100" step="10" oninput="sliderUpdate('zoom',this.value)" onchange="cmd('zoom '+this.value)">
          <span class="val" id="zoom-val">100</span>
        </div>
      </div>
      <div class="panel">
        <h3>Focus</h3>
        <div><button class="btn" onclick="cmd('focus')">Refocus</button></div>
