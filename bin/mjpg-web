#!/usr/bin/env python3
"""Web control panel for mjpg-streamer camera."""

import http.server
import json
import subprocess
import urllib.parse

PORT = 8081

HTML = """<!DOCTYPE html>
<html>
<head>
<title>Camera Control</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, sans-serif; background: #1a1a2e; color: #eee; }
  .container { max-width: 1200px; margin: 0 auto; padding: 10px; }
  h1 { text-align: center; padding: 10px; color: #e94560; font-size: 1.3em; }
  .stream { text-align: center; margin: 10px 0; }
  .stream img { width: 100%; max-width: 1100px; border-radius: 8px; border: 2px solid #333; }
  .controls { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 15px; margin-top: 15px; }
  .panel { background: #16213e; border-radius: 8px; padding: 15px; }
  .panel h3 { color: #e94560; margin-bottom: 10px; font-size: 0.95em; }
  .btn-group { display: flex; gap: 6px; flex-wrap: wrap; }
  .btn { padding: 8px 16px; border: none; border-radius: 6px; cursor: pointer;
         background: #0f3460; color: #eee; font-size: 0.9em; transition: background 0.2s; }
  .btn:hover { background: #e94560; }
  .btn.active { background: #e94560; }
  .slider-row { display: flex; align-items: center; gap: 10px; margin: 8px 0; }
  .slider-row label { min-width: 70px; font-size: 0.9em; }
  .slider-row input[type=range] { flex: 1; accent-color: #e94560; }
  .slider-row .val { min-width: 40px; text-align: right; font-size: 0.9em; color: #e94560; }
  #status { text-align: center; color: #888; font-size: 0.85em; margin-top: 10px; min-height: 20px; }
</style>
</head>
<body>
<div class="container">
  <h1>Camera Control Panel</h1>
  <div class="stream">
    <img id="stream" src="http://__HOST__:8080/?action=stream" alt="Camera Stream">
  </div>
  <div id="status"></div>
  <div class="controls">
    <div class="panel">
      <h3>Mode</h3>
      <div class="btn-group">
        <button class="btn" onclick="cmd('day')">Day</button>
        <button class="btn" onclick="cmd('night')">Night</button>
        <button class="btn" onclick="cmd('indoor')">Indoor</button>
      </div>
    </div>
    <div class="panel">
      <h3>Resolution</h3>
      <div class="btn-group">
        <button class="btn" onclick="cmd('res low')">Low 480p</button>
        <button class="btn" onclick="cmd('res mid')">Mid 720p</button>
        <button class="btn" onclick="cmd('res high')">High 1080p</button>
      </div>
    </div>
    <div class="panel">
      <h3>Rotation</h3>
      <div class="btn-group">
        <button class="btn" onclick="cmd('rotate 0')">0&deg;</button>
        <button class="btn" onclick="cmd('rotate 90')">90&deg;</button>
        <button class="btn" onclick="cmd('rotate 180')">180&deg;</button>
        <button class="btn" onclick="cmd('rotate 270')">270&deg;</button>
      </div>
    </div>
    <div class="panel">
      <h3>FPS</h3>
      <div class="btn-group">
        <button class="btn" onclick="cmd('fps 5')">5</button>
        <button class="btn" onclick="cmd('fps 10')">10</button>
        <button class="btn" onclick="cmd('fps 15')">15</button>
        <button class="btn" onclick="cmd('fps 24')">24</button>
        <button class="btn" onclick="cmd('fps 30')">30</button>
      </div>
    </div>
    <div class="panel">
      <h3>Brightness</h3>
      <div class="slider-row">
        <label>Brightness</label>
        <input type="range" id="bright" min="0" max="100" value="58" oninput="sliderUpdate('bright',this.value)" onchange="cmd('bright '+this.value)">
        <span class="val" id="bright-val">58</span>
      </div>
    </div>
    <div class="panel">
      <h3>Zoom</h3>
      <div class="slider-row">
        <label>Zoom</label>
        <input type="range" id="zoom" min="100" max="500" value="100" step="10" oninput="sliderUpdate('zoom',this.value)" onchange="cmd('zoom '+this.value)">
        <span class="val" id="zoom-val">100</span>
      </div>
    </div>
  </div>
</div>
<script>
function cmd(c) {
  document.getElementById('status').textContent = 'Applying: ' + c + '...';
  fetch('/api?cmd=' + encodeURIComponent(c))
    .then(r => r.json())
    .then(d => {
      document.getElementById('status').textContent = d.output || 'Done';
      if (c.startsWith('res ') || c.startsWith('rotate ') || c.startsWith('fps ') || c === 'day' || c === 'night' || c === 'indoor') {
        setTimeout(() => {
          let img = document.getElementById('stream');
          img.src = img.src.split('?')[0] + '?action=stream&t=' + Date.now();
        }, 5000);
      }
    })
    .catch(e => document.getElementById('status').textContent = 'Error: ' + e);
}
function sliderUpdate(id, val) {
  document.getElementById(id + '-val').textContent = val;
}
// Load current status
fetch('/api?cmd=status').then(r=>r.json()).then(d=>{
  let lines = d.output.split('\\n');
  lines.forEach(l => {
    let m;
    if (m = l.match(/Brightness: (\\d+)/)) document.getElementById('bright').value = m[1], sliderUpdate('bright',m[1]);
    if (m = l.match(/Zoom: (\\d+)/)) document.getElementById('zoom').value = m[1], sliderUpdate('zoom',m[1]);
  });
});
</script>
</body>
</html>"""

class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path.startswith('/api'):
            query = urllib.parse.urlparse(self.path).query
            params = urllib.parse.parse_qs(query)
            cmd = params.get('cmd', ['status'])[0]
            # Only allow known commands
            allowed = ['day', 'night', 'indoor', 'status']
            prefixes = ['res ', 'rotate ', 'bright ', 'zoom ', 'fps ']
            if cmd not in allowed and not any(cmd.startswith(p) for p in prefixes):
                self.send_response(400)
                self.end_headers()
                self.wfile.write(b'{"error":"invalid command"}')
                return
            parts = cmd.split()
            result = subprocess.run(['/usr/local/bin/mjpg-ctl'] + parts,
                                    capture_output=True, text=True, timeout=30)
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            output = (result.stdout + result.stderr).strip()
            self.wfile.write(json.dumps({"output": output}).encode())
        else:
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            host = self.headers.get('Host', '10.0.0.238:8081').split(':')[0]
            self.wfile.write(HTML.replace('__HOST__', host).encode())

    def log_message(self, format, *args):
        pass

if __name__ == '__main__':
    server = http.server.HTTPServer(('0.0.0.0', PORT), Handler)
    print(f"Control panel running on http://0.0.0.0:{PORT}")
    server.serve_forever()
